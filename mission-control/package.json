{
  "name": "mission-control",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "biome lint apps packages tests",
    "format": "biome format --write apps packages tests",
    "check": "biome check apps packages tests",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:integration": "pnpm --filter @mc/integration test",
    "db:migrate": "node db/migrate.js",
    "db:seed": "tsx db/seed.ts",
    "agents:sync-openclaw": "tsx ops/sync-openclaw-agents.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@10.17.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "dependencies": {
    "pg": "^8.19.0"
  }
}
