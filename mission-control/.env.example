# ── Database ──────────────────────────────────────────
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=mission_control
PG_PORT=5432

# ── Redis ─────────────────────────────────────────────
REDIS_PORT=6379

# ── Control API ───────────────────────────────────────
API_PORT=3000
LOG_LEVEL=info

# ── Mission UI ────────────────────────────────────────
UI_PORT=5173

# ── Workers ───────────────────────────────────────────
OFFLINE_THRESHOLD_MS=30000
DETECTOR_POLL_MS=10000
ASSIGNER_POLL_MS=5000
LEASE_SECONDS=120
NOTIF_POLL_MS=5000

# ── OpenClaw (optional — only used with --profile openclaw) ──
# OPENCLAW_GATEWAY_URL=http://your-openclaw-gateway:8080
# OPENCLAW_GATEWAY_TOKEN=your-secret-token
# OPENCLAW_DEFAULT_MODEL=
# OPENCLAW_DISPATCH_POLL_MS=10000
