# This file shows the structure of /etc/openclaw/openclaw.env inside the VM.
# The actual env file is managed via: orb -m openclaw-vm -u root vim /etc/openclaw/openclaw.env

# OpenClaw Gateway
OPENCLAW_GATEWAY_TOKEN=replace-with-a-long-random-token
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_GATEWAY_PORT=18789

# State directory
HOME=/home/filipefernandes

# Timezone
TZ=America/Sao_Paulo

# Optional provider credentials (set only what you use)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# PERPLEXITY_API_KEY=
# GEMINI_API_KEY=
# BRAVE_API_KEY=
# GH_TOKEN=
# LINEAR_API_KEY=
# DISCORD_BOT_TOKEN=
